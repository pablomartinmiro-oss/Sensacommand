generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlayerSource {
  WALK_IN
  REFERRAL
  SOCIAL_MEDIA
  WEBSITE
  PLAYBYPOINT
  OTHER
}

enum PlayerStatus {
  NEW
  ACTIVE
  HOT_LEAD
  COLD_LEAD
  CONVERTED
  CHURNED
}

enum MembershipType {
  NONE
  STANDARD
  UNLIMITED
}

enum VisitType {
  CASUAL
  MEMBER_SESSION
  LESSON
  TOURNAMENT
  PRIVATE_EVENT
}

enum PaymentType {
  COURT_RENTAL
  MEMBERSHIP
  LESSON
  PRO_SHOP
  EVENT
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  PLAYBYPOINT
}

enum MessageChannel {
  WHATSAPP
  EMAIL
  SMS
  IN_APP
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageStatus {
  DRAFT
  SENT
  DELIVERED
  READ
  FAILED
}

enum TemplateCategory {
  WELCOME
  WIN_BACK
  UPSELL
  REMINDER
  PROMO
  CUSTOM
}

model Player {
  id                  String         @id @default(cuid())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  firstName           String
  lastName            String
  email               String?        @unique
  phone               String?
  whatsappPhone       String?
  source              PlayerSource   @default(OTHER)
  status              PlayerStatus   @default(NEW)
  membershipType      MembershipType @default(NONE)
  membershipStartDate DateTime?
  membershipEndDate   DateTime?
  monthlyRate         Decimal?
  notes               String?        @db.Text
  tags                String[]

  visits          Visit[]
  payments        Payment[]
  messages        Message[]
  linkedGoals     Goal[]           @relation("GoalLinkedPlayers")
  automationLogs  AutomationLog[]

  @@index([status])
  @@index([membershipType])
  @@index([email])
}

model Visit {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  playerId    String
  player      Player    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  courtNumber Int
  date        DateTime  @db.Date
  startTime   DateTime
  endTime     DateTime
  type        VisitType @default(CASUAL)
  amountPaid  Decimal   @default(0)
  notes       String?

  @@index([playerId])
  @@index([date])
  @@index([courtNumber])
}

model Payment {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  playerId    String?
  player      Player?       @relation(fields: [playerId], references: [id], onDelete: SetNull)
  date        DateTime      @db.Date
  amount      Decimal
  type        PaymentType
  method      PaymentMethod @default(CARD)
  description String?
  receiptRef  String?

  @@index([playerId])
  @@index([date])
  @@index([type])
}

model DailyRevenue {
  id           String   @id @default(cuid())
  date         DateTime @unique @db.Date
  courtRentals Decimal  @default(0)
  memberships  Decimal  @default(0)
  lessons      Decimal  @default(0)
  proShop      Decimal  @default(0)
  events       Decimal  @default(0)
  other        Decimal  @default(0)
  totalRevenue Decimal  @default(0)
  notes        String?

  @@index([date])
}

model Message {
  id           String           @id @default(cuid())
  createdAt    DateTime         @default(now())
  playerId     String
  player       Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  channel      MessageChannel
  direction    MessageDirection @default(OUTBOUND)
  subject      String?
  body         String           @db.Text
  status       MessageStatus    @default(DRAFT)
  templateUsed String?

  @@index([playerId])
  @@index([status])
}

model MessageTemplate {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  name      String           @unique
  channel   MessageChannel
  category  TemplateCategory
  subject   String?
  body      String           @db.Text
  isActive  Boolean          @default(true)
}

model AIConversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  messages  Json[]
  title     String?
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

// ---------------------------------------------------------------------------
// Goals Module
// ---------------------------------------------------------------------------

enum TeamMemberRole {
  GM
  COACH
  FRONT_DESK
  MARKETING
  OPERATIONS
  FINANCE
  PRO_SHOP
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
  FUTURE_IDEA
  ON_HOLD
  ONGOING
}

enum GoalPriority {
  HIGH
  MEDIUM
  LOW
  NONE
}

model TeamMember {
  id        String         @id @default(cuid())
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  firstName String
  lastName  String
  email     String?        @unique
  role      TeamMemberRole
  isActive  Boolean        @default(true)

  assignedGoals   Goal[]           @relation("GoalAssignees")
  comments        GoalComment[]
  leaveAllowances LeaveAllowance[]
  leaveRequests   LeaveRequest[]

  @@index([role])
}

model Goal {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  title         String
  description   String?      @db.Text
  status        GoalStatus   @default(NOT_STARTED)
  priority      GoalPriority @default(NONE)
  categories    String[]
  dueDate       DateTime?
  dateRequested DateTime?
  completedDate DateTime?
  sortOrder     Int          @default(0)
  notes         String?      @db.Text

  assignees     TeamMember[]  @relation("GoalAssignees")
  comments      GoalComment[]
  linkedPlayers Player[]      @relation("GoalLinkedPlayers")
  activities    GoalActivity[]

  @@index([status])
  @@index([priority])
  @@index([dueDate])
}

model GoalActivity {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  action      String
  fromValue   String?
  toValue     String?
  performedBy String   @default("system")

  @@index([goalId])
  @@index([createdAt])
}

model GoalComment {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  goalId    String
  goal      Goal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  authorId  String
  author    TeamMember @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String     @db.Text

  @@index([goalId])
  @@index([authorId])
}

// ---------------------------------------------------------------------------
// Automation Engine
// ---------------------------------------------------------------------------

model AutomationLog {
  id              String   @id @default(cuid())
  automationType  String
  targetPlayerId  String?
  targetPlayer    Player?  @relation(fields: [targetPlayerId], references: [id])
  action          String
  message         String?  @db.Text
  channel         String?
  status          String
  error           String?
  dryRun          Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([automationType])
  @@index([targetPlayerId])
  @@index([createdAt])
  @@index([status])
}

model AutomationConfig {
  id            String    @id @default(cuid())
  type          String    @unique
  name          String
  description   String
  enabled       Boolean   @default(true)
  schedule      String
  lastRun       DateTime?
  nextRun       DateTime?
  config        Json      @default("{}")
  createdBy     String?
  aiPrompt      String?   @db.Text
  triggerType   String?
  actionType    String?
  triggerConfig Json?
  actionConfig  Json?
  conditions    Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Social Media
// ---------------------------------------------------------------------------

model SocialPost {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  title       String
  content     String    @db.Text
  platform    String
  mediaType   String?
  mediaUrl    String?
  hashtags    String[]
  scheduledFor DateTime?
  status      String    @default("DRAFT")
  postedAt    DateTime?
  notes       String?   @db.Text
  category    String?
  createdById String?
  metrics     Json?
  campaignId  String?
  campaign    SocialCampaign? @relation(fields: [campaignId], references: [id])

  @@index([status])
  @@index([platform])
  @@index([scheduledFor])
  @@index([campaignId])
}

model SocialCampaign {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  name        String
  description String?  @db.Text
  startDate   DateTime
  endDate     DateTime
  status      String   @default("ACTIVE")
  posts       SocialPost[]
}

// ---------------------------------------------------------------------------
// Webhooks
// ---------------------------------------------------------------------------

model WebhookEvent {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  webhookId   String    @unique
  event       String
  source      String    @default("playbypoint")
  payload     Json
  status      String    @default("pending")
  error       String?   @db.Text
  processedAt DateTime?
  playerId    String?
  visitId     String?
  paymentId   String?

  @@index([event])
  @@index([status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Leave / PTO Tracker
// ---------------------------------------------------------------------------

model LeaveAllowance {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id])
  year         Int
  totalDays    Int        @default(15)
  usedDays     Int        @default(0)

  @@unique([teamMemberId, year])
}

model LeaveRequest {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id])
  startDate    DateTime
  endDate      DateTime
  days         Int
  type         String    @default("PTO")
  reason       String?
  status       String    @default("PENDING")
  approvedBy   String?
  approvedAt   DateTime?
  notes        String?   @db.Text

  @@index([teamMemberId])
  @@index([status])
  @@index([startDate])
}
